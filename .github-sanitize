#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# .github-sanitize — Pre-push sanitization for public GitHub remote
# =============================================================================
# Validates that no sensitive data leaks to the public GitHub repository.
# Run manually before pushing to GitHub, or integrate as a pre-push hook.
#
# Usage:
#   ./.github-sanitize          Run all checks
#   ./.github-sanitize --fix    Show what would need fixing (dry-run)
#
# GitLab (private) does NOT need sanitization — push freely.
# =============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ERRORS=0
WARNINGS=0

fail()  { echo -e "${RED}[FAIL]${NC}  $*"; ((ERRORS++)); }
warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; ((WARNINGS++)); }
pass()  { echo -e "${GREEN}[PASS]${NC}  $*"; }

echo "=== GitHub Sanitization Check ==="
echo ""

# Domain pattern split to avoid self-detection
SANITIZE_DOMAIN="aegis""group.ch"
SANITIZE_REGEX="aegis""group\\.ch"

# --- Check 1: No internal domain names in tracked files ---
echo "Checking for internal domain references..."
DOMAIN_HITS=$(git ls-files -z | xargs -0 grep -l "${SANITIZE_REGEX}" 2>/dev/null || true)
if [ -n "$DOMAIN_HITS" ]; then
  fail "Internal domain '${SANITIZE_DOMAIN}' found in tracked files:"
  echo "$DOMAIN_HITS" | sed 's/^/        /'
else
  pass "No internal domain references in tracked files"
fi

# --- Check 2: No internal domains in git history (file content only) ---
echo "Checking git history for domain leaks..."
# Exclude Author/Committer lines (git identity is expected) and remote tracking refs
HISTORY_HITS=$(git log main -p 2>/dev/null | grep -v '^Author:' | grep -v '^Commit:' | grep -c "${SANITIZE_REGEX}" || echo "0")
if [ "$HISTORY_HITS" -gt 0 ]; then
  fail "Found ${HISTORY_HITS} references to '${SANITIZE_DOMAIN}' in git history (file diffs)"
  echo "        Run: git filter-repo --replace-text <replacements-file> --force"
else
  pass "Git history is clean of internal domains (file content)"
fi

# --- Check 3: No private keys ---
echo "Checking for private keys..."
KEY_HITS=$(git ls-files -z | xargs -0 grep -l 'PRIVATE KEY' 2>/dev/null || true)
if [ -n "$KEY_HITS" ]; then
  fail "Private key material found in:"
  echo "$KEY_HITS" | sed 's/^/        /'
else
  pass "No private keys in tracked files"
fi

# --- Check 4: No .tfvars (real ones) tracked ---
echo "Checking for tracked .tfvars files..."
TFVARS_HITS=$(git ls-files '*.tfvars' | grep -v '\.example$' || true)
if [ -n "$TFVARS_HITS" ]; then
  fail "Real .tfvars files tracked (should be gitignored):"
  echo "$TFVARS_HITS" | sed 's/^/        /'
else
  pass "No real .tfvars files tracked"
fi

# --- Check 5: No kubeconfig tracked ---
echo "Checking for tracked kubeconfig files..."
KUBE_HITS=$(git ls-files | grep -i kubeconfig || true)
if [ -n "$KUBE_HITS" ]; then
  fail "Kubeconfig files tracked:"
  echo "$KUBE_HITS" | sed 's/^/        /'
else
  pass "No kubeconfig files tracked"
fi

# --- Check 6: No .env files tracked ---
echo "Checking for tracked .env files..."
ENV_HITS=$(git ls-files '.env' '.env.*' | grep -v '\.example$' || true)
if [ -n "$ENV_HITS" ]; then
  fail "Environment files tracked (should be gitignored):"
  echo "$ENV_HITS" | sed 's/^/        /'
else
  pass "No .env files tracked"
fi

# --- Check 7: No Claude/superpowers docs tracked ---
echo "Checking for AI-generated docs..."
AI_HITS=$(git ls-files | grep -E '(superpowers|\.claude)' || true)
if [ -n "$AI_HITS" ]; then
  fail "AI-generated files tracked:"
  echo "$AI_HITS" | sed 's/^/        /'
else
  pass "No AI-generated docs tracked"
fi

# --- Check 8: CA certificate is public cert only (no private key) ---
echo "Checking CA certificate..."
if [ -f shared/aegis-root-ca.pem ]; then
  if grep -q 'PRIVATE KEY' shared/aegis-root-ca.pem; then
    fail "shared/aegis-root-ca.pem contains a private key!"
  else
    pass "shared/aegis-root-ca.pem is a public certificate only"
  fi
else
  pass "No CA certificate file (skipped)"
fi

# --- Check 9: Hardcoded IPs (non-RFC1918 examples) ---
echo "Checking for hardcoded internal IPs..."
IP_HITS=$(git ls-files -z | xargs -0 grep -nE '(192\.168\.[0-9]+\.[0-9]+|10\.[0-9]+\.[0-9]+\.[0-9]+|172\.(1[6-9]|2[0-9]|3[01])\.[0-9]+\.[0-9]+)' 2>/dev/null \
  | grep -v '\.pem:' \
  | grep -v 'iptables' \
  | grep -v 'example' \
  | grep -v '\.md:' \
  || true)
if [ -n "$IP_HITS" ]; then
  warn "Possible internal IPs in tracked files (review manually):"
  echo "$IP_HITS" | head -10 | sed 's/^/        /'
else
  pass "No suspicious internal IPs found"
fi

# --- Summary ---
echo ""
echo "=== Summary ==="
if [ "$ERRORS" -gt 0 ]; then
  echo -e "${RED}FAILED: ${ERRORS} error(s), ${WARNINGS} warning(s)${NC}"
  echo "Fix issues above before pushing to GitHub."
  exit 1
elif [ "$WARNINGS" -gt 0 ]; then
  echo -e "${YELLOW}PASSED with ${WARNINGS} warning(s)${NC}"
  echo "Review warnings above. Push to GitHub at your discretion."
  exit 0
else
  echo -e "${GREEN}ALL CHECKS PASSED${NC}"
  echo "Safe to push to GitHub."
  exit 0
fi
