# Golden Image Builder — Local Environment
# Copy to .env and fill in your values. This file is sourced by build.sh.

# Proxy-cache URLs (for airgapped/proxied environments)
# Leave empty to use upstream repos directly.
PROXY_CACHE_DL_URL=https://dl.example.com
PROXY_CACHE_YUM_URL=https://yum.example.com
# EPEL full baseurl — EPEL is typically hosted separately from the main yum proxy
PROXY_CACHE_EPEL_URL=https://epel.example.com/epel/9/Everything/x86_64
PROXY_CACHE_APT_URL=https://apt.example.com

# Terraform variables (override defaults in variables.tf)
# export TF_VAR_vm_namespace=rke2-prod
# export TF_VAR_harvester_network_name=vm-network
# export TF_VAR_harvester_network_namespace=default

# Image naming (optional — overrides auto-generated name)
# export IMAGE_NAME_OVERRIDE=rocky-9.7-cis-20260313

# Git config for CI tagging (used by .gitlab-ci.yml)
# CI_GIT_EMAIL=ci@example.com
