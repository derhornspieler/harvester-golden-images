# =============================================================================
# GitLab CI — Golden Image Automated Build Pipeline (Example)
# =============================================================================
# Copy this file to .gitlab-ci.yml and configure the variables below.
# Triggered when upstream-versions.json is updated (by Argo watcher).
# Builds golden images with version-aware naming on a dedicated runner.
# =============================================================================

stages:
  - detect
  - build
  - tag
  - cleanup
  - sync

workflow:
  rules:
    - if: $CI_PIPELINE_SOURCE == "push" && $CI_COMMIT_BRANCH == "main"
    - if: $CI_PIPELINE_SOURCE == "web"
    - if: $CI_PIPELINE_SOURCE == "trigger"
    - if: $CI_PIPELINE_SOURCE == "api"

# Required GitLab CI/CD project variables:
#   PROXY_CACHE_DL_URL    — Cloud image download proxy (e.g., https://dl.example.com)
#   PROXY_CACHE_YUM_URL   — RPM repo proxy (e.g., https://yum.example.com)
#   PROXY_CACHE_APT_URL   — APT repo proxy (e.g., https://apt.example.com)
#   CI_GIT_EMAIL          — Email for CI git commits (e.g., ci@example.com)
#   DOMAIN                — Your org domain (e.g., example.com) — group-level variable
variables:
  TF_VAR_vm_namespace: "default"
  TF_VAR_harvester_kubeconfig_path: "/etc/harvester/kubeconfig-harvester.yaml"
  TF_VAR_harvester_network_name: "vm-network"
  TF_VAR_harvester_network_namespace: "default"
  TF_VAR_builder_image_url: "${PROXY_CACHE_DL_URL}/rocky/9/images/x86_64/Rocky-9-GenericCloud-Base.latest.x86_64.qcow2"
  TF_VAR_repo_mirror_url: "${PROXY_CACHE_YUM_URL}"

# Install tools missing from hashicorp/terraform Alpine image
before_script:
  - apk add --no-cache jq curl
  - curl -sLo /usr/local/bin/kubectl "https://dl.k8s.io/release/$(curl -sL https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"
  - chmod +x /usr/local/bin/kubectl

# -----------------------------------------------------------------------------
# Stage: detect — Diff upstream-versions.json to find which distros changed
# -----------------------------------------------------------------------------
detect-changes:
  stage: detect
  tags:
    - terraform
  script:
    - |
      set -euo pipefail

      IMAGE_DATE=$(date +%Y%m%d)
      echo "IMAGE_DATE=${IMAGE_DATE}" >> detect.env

      ROCKY_VERSION=$(jq -r '.rocky9.version // ""' upstream-versions.json)
      DEBIAN13_VERSION=$(jq -r '.debian13.version // ""' upstream-versions.json)
      echo "ROCKY_VERSION=${ROCKY_VERSION}" >> detect.env
      echo "DEBIAN13_VERSION=${DEBIAN13_VERSION}" >> detect.env

      BUILD_ROCKY9="false"
      BUILD_DEBIAN13="false"

      OLD_ROCKY_CHECKSUM=$(git show HEAD~1:upstream-versions.json 2>/dev/null | jq -r '.rocky9.checksum // ""' 2>/dev/null || echo "")
      NEW_ROCKY_CHECKSUM=$(jq -r '.rocky9.checksum // ""' upstream-versions.json)
      if [ "$OLD_ROCKY_CHECKSUM" != "$NEW_ROCKY_CHECKSUM" ]; then
        BUILD_ROCKY9="true"
        echo "Rocky 9 ${ROCKY_VERSION} — checksum changed, will build"
      else
        echo "Rocky 9 — no change detected"
      fi

      OLD_DEBIAN_CHECKSUM=$(git show HEAD~1:upstream-versions.json 2>/dev/null | jq -r '.debian13.checksum // ""' 2>/dev/null || echo "")
      NEW_DEBIAN_CHECKSUM=$(jq -r '.debian13.checksum // ""' upstream-versions.json)
      if [ "$OLD_DEBIAN_CHECKSUM" != "$NEW_DEBIAN_CHECKSUM" ]; then
        BUILD_DEBIAN13="true"
        echo "Debian 13 ${DEBIAN13_VERSION} — checksum changed, will build"
      else
        echo "Debian 13 — no change detected"
      fi

      # On manual/API trigger, build everything that has version info
      if [ "$CI_PIPELINE_SOURCE" = "web" ] || [ "$CI_PIPELINE_SOURCE" = "trigger" ] || [ "$CI_PIPELINE_SOURCE" = "api" ]; then
        echo "Manual/API trigger — building all distros with version info"
        [ -n "$ROCKY_VERSION" ] && BUILD_ROCKY9="true"
        [ -n "$DEBIAN13_VERSION" ] && BUILD_DEBIAN13="true"
      fi

      echo "BUILD_ROCKY9=${BUILD_ROCKY9}" >> detect.env
      echo "BUILD_DEBIAN13=${BUILD_DEBIAN13}" >> detect.env
  artifacts:
    reports:
      dotenv: detect.env

# -----------------------------------------------------------------------------
# Stage: build — Run golden image builds (conditional via script check)
# -----------------------------------------------------------------------------
# Build jobs use script-level checks instead of rules:if for dotenv variables,
# since rules:if evaluates before dotenv artifacts are loaded.

build-cis-rocky9:
  stage: build
  tags:
    - terraform
  resource_group: terraform
  needs:
    - job: detect-changes
      artifacts: true
  timeout: 120m
  variables:
    TF_VAR_cloud_image_url: "${PROXY_CACHE_DL_URL}/rocky/9/images/x86_64/Rocky-9-GenericCloud-Base.latest.x86_64.qcow2"
  script:
    - |
      set -euo pipefail
      if [ "${BUILD_ROCKY9}" != "true" ]; then
        echo "Rocky 9 not changed — skipping"
        exit 0
      fi
      export IMAGE_NAME_OVERRIDE="rocky-${ROCKY_VERSION}-cis-${IMAGE_DATE}"
      KUBECTL="kubectl --kubeconfig=${TF_VAR_harvester_kubeconfig_path}"
      if $KUBECTL get virtualmachineimages.harvesterhci.io "${IMAGE_NAME_OVERRIDE}" -n "${TF_VAR_vm_namespace}" &>/dev/null; then
        echo "Image ${IMAGE_NAME_OVERRIDE} already exists in Harvester — skipping build"
        exit 0
      fi
      # Optional: inject private CA for proxy-cache TLS
      # export TF_VAR_private_ca_pem="$(cat shared/your-ca.pem)"
      echo "Building CIS Rocky 9 as: ${IMAGE_NAME_OVERRIDE}"
      ./build.sh build cis-rocky9

build-cis-debian13:
  stage: build
  tags:
    - terraform
  resource_group: terraform
  needs:
    - job: detect-changes
      artifacts: true
  timeout: 120m
  variables:
    TF_VAR_repo_mirror_url: "${PROXY_CACHE_APT_URL}"
    TF_VAR_cloud_image_url: ""
  script:
    - |
      set -euo pipefail
      if [ "${BUILD_DEBIAN13}" != "true" ]; then
        echo "Debian 13 not changed — skipping"
        exit 0
      fi
      export IMAGE_NAME_OVERRIDE="debian-${DEBIAN13_VERSION}-cis-${IMAGE_DATE}"
      KUBECTL="kubectl --kubeconfig=${TF_VAR_harvester_kubeconfig_path}"
      if $KUBECTL get virtualmachineimages.harvesterhci.io "${IMAGE_NAME_OVERRIDE}" -n "${TF_VAR_vm_namespace}" &>/dev/null; then
        echo "Image ${IMAGE_NAME_OVERRIDE} already exists in Harvester — skipping build"
        exit 0
      fi
      # Optional: inject private CA for proxy-cache TLS
      # export TF_VAR_private_ca_pem="$(cat shared/your-ca.pem)"
      echo "Building CIS Debian 13 as: ${IMAGE_NAME_OVERRIDE}"
      ./build.sh build cis-debian13

build-rke2:
  stage: build
  tags:
    - terraform
  resource_group: terraform
  needs:
    - job: detect-changes
      artifacts: true
  timeout: 60m
  variables:
    TF_VAR_rocky_image_url: "${PROXY_CACHE_DL_URL}/rocky/9/images/x86_64/Rocky-9-GenericCloud-Base.latest.x86_64.qcow2"
    TF_VAR_rocky_repo_url: "${PROXY_CACHE_YUM_URL}"
    TF_VAR_rke2_repo_url: "${PROXY_CACHE_YUM_URL}/rke2/latest"
  script:
    - |
      set -euo pipefail
      if [ "${BUILD_ROCKY9}" != "true" ]; then
        echo "Rocky 9 not changed — skipping RKE2 build"
        exit 0
      fi
      export IMAGE_NAME_OVERRIDE="rocky-${ROCKY_VERSION}-rke2-${IMAGE_DATE}"
      KUBECTL="kubectl --kubeconfig=${TF_VAR_harvester_kubeconfig_path}"
      if $KUBECTL get virtualmachineimages.harvesterhci.io "${IMAGE_NAME_OVERRIDE}" -n "${TF_VAR_vm_namespace}" &>/dev/null; then
        echo "Image ${IMAGE_NAME_OVERRIDE} already exists in Harvester — skipping build"
        exit 0
      fi
      # Optional: inject private CA for proxy-cache TLS
      # export TF_VAR_private_ca_pem="$(cat shared/your-ca.pem)"
      echo "Building RKE2 Rocky 9 as: ${IMAGE_NAME_OVERRIDE}"
      ./build.sh build rke2

# -----------------------------------------------------------------------------
# Stage: tag — Git-tag the build
# -----------------------------------------------------------------------------
tag-build:
  stage: tag
  tags:
    - terraform
  when: always
  needs:
    - job: detect-changes
      artifacts: true
    - job: build-cis-rocky9
      optional: true
    - job: build-cis-debian13
      optional: true
    - job: build-rke2
      optional: true
  script:
    - |
      set -euo pipefail

      KUBECTL="kubectl --kubeconfig=${TF_VAR_harvester_kubeconfig_path}"
      NS="${TF_VAR_vm_namespace}"

      git remote set-url origin "https://gitlab-ci-token:${CI_JOB_TOKEN}@${CI_SERVER_HOST}/${CI_PROJECT_PATH}.git"
      git config user.name "GitLab CI"
      git config user.email "${CI_GIT_EMAIL:-ci@localhost}"

      TAGGED=0

      if [ "${BUILD_ROCKY9}" = "true" ]; then
        CIS_IMAGE="rocky-${ROCKY_VERSION}-cis-${IMAGE_DATE}"
        RKE2_IMAGE="rocky-${ROCKY_VERSION}-rke2-${IMAGE_DATE}"
        CIS_OK=$($KUBECTL get virtualmachineimages.harvesterhci.io "$CIS_IMAGE" -n "$NS" &>/dev/null && echo "true" || echo "false")
        RKE2_OK=$($KUBECTL get virtualmachineimages.harvesterhci.io "$RKE2_IMAGE" -n "$NS" &>/dev/null && echo "true" || echo "false")

        if [ "$CIS_OK" = "true" ] || [ "$RKE2_OK" = "true" ]; then
          TAG="rocky9/${ROCKY_VERSION}-${IMAGE_DATE}"
          DETAILS=""
          [ "$CIS_OK" = "true" ] && DETAILS="CIS"
          [ "$RKE2_OK" = "true" ] && DETAILS="${DETAILS:+$DETAILS + }RKE2"
          git tag -a "$TAG" -m "Rocky ${ROCKY_VERSION} golden images built ${IMAGE_DATE} (${DETAILS})"
          echo "Tagged: ${TAG} (${DETAILS})"
          TAGGED=1
        else
          echo "Rocky 9 — no images found in Harvester, skipping tag"
        fi
      fi

      if [ "${BUILD_DEBIAN13}" = "true" ]; then
        DEB_IMAGE="debian-${DEBIAN13_VERSION}-cis-${IMAGE_DATE}"
        if $KUBECTL get virtualmachineimages.harvesterhci.io "$DEB_IMAGE" -n "$NS" &>/dev/null; then
          TAG="debian13/${DEBIAN13_VERSION}-${IMAGE_DATE}"
          git tag -a "$TAG" -m "Debian ${DEBIAN13_VERSION} golden image built ${IMAGE_DATE}"
          echo "Tagged: ${TAG}"
          TAGGED=1
        else
          echo "Debian 13 — image not found in Harvester, skipping tag"
        fi
      fi

      if [ "$TAGGED" -eq 1 ]; then
        git push origin --tags
      else
        echo "No successful builds to tag"
      fi

# -----------------------------------------------------------------------------
# Stage: cleanup — Remove old images (manual trigger only)
# -----------------------------------------------------------------------------
cleanup-old-images:
  stage: cleanup
  tags:
    - terraform
  when: manual
  allow_failure: true
  variables:
    KEEP_COUNT: "3"
  script:
    - |
      set -euo pipefail
      echo "Image cleanup — keeping last ${KEEP_COUNT} per type"
      echo "TODO: implement image retention policy"
      echo "This will use: ./build.sh list + ./build.sh delete"

# -----------------------------------------------------------------------------
# Stage: sync — Push sanitized mirror to external Git host (optional)
# -----------------------------------------------------------------------------
# This example uses git-filter-repo to preserve commit history while scrubbing
# PII (domains, usernames, org names) before pushing to a public mirror.
# Credentials are fetched from Vault via JWT auth at runtime.
#
# Prerequisites:
#   - Vault KV secret at kv/services/ci/github-mirror with keys:
#       github-user     — GitHub username or org
#       ssh-private-key — Deploy key with push access to the mirror repo
#       api-token       — GitHub PAT for checking Actions status (optional)
#   - GitLab id_tokens configured for Vault JWT auth
#   - Runner with 'shared' tag (does not need Harvester kubeconfig)
sync-to-mirror:
  stage: sync
  needs: []
  tags:
    - shared
  image: docker.io/alpine:3.23
  id_tokens:
    VAULT_ID_TOKEN:
      aud: https://gitlab.example.com
  rules:
    - if: $CI_COMMIT_BRANCH == "main"
      when: always
  variables:
    VAULT_ADDR: "https://vault.example.com"
  before_script:
    - apk add --no-cache git openssh-client python3 py3-pip curl jq ca-certificates
    # If using a private CA, install it into the system trust store
    - |
      if [ -f /etc/ssl/certs/vault-root-ca.pem ]; then
        cp /etc/ssl/certs/vault-root-ca.pem /usr/local/share/ca-certificates/vault-root-ca.crt
        update-ca-certificates 2>/dev/null
      fi
    - pip install git-filter-repo --break-system-packages 2>/dev/null
    - git config --global user.name "GitLab Mirror"
    - git config --global user.email "mirror@ci.local"
  script:
    - |
      set -euo pipefail

      # --- Vault authentication (GitLab 17+ id_tokens) ---
      VAULT_TOKEN=$(curl -sf \
        --cacert /etc/ssl/certs/vault-root-ca.pem \
        --request POST \
        --data "{\"jwt\": \"${VAULT_ID_TOKEN}\", \"role\": \"gitlab-ci\"}" \
        "${VAULT_ADDR}/v1/auth/jwt/login" | \
        jq -r '.auth.client_token')

      if [ -z "${VAULT_TOKEN}" ] || [ "${VAULT_TOKEN}" = "null" ]; then
        echo "ERROR: Failed to authenticate to Vault"
        exit 1
      fi
      echo "Vault auth successful"

      # --- Fetch mirror credentials from Vault ---
      GH_CREDS=$(curl -sf \
        --cacert /etc/ssl/certs/vault-root-ca.pem \
        -H "X-Vault-Token: ${VAULT_TOKEN}" \
        "${VAULT_ADDR}/v1/kv/data/services/ci/github-mirror")

      GH_SSH_KEY=$(echo "${GH_CREDS}" | jq -r '.data.data["ssh-private-key"]')
      GH_USER=$(echo "${GH_CREDS}" | jq -r '.data.data["github-user"]')
      GITHUB_API_TOKEN=$(echo "${GH_CREDS}" | jq -r '.data.data["api-token"]')
      PROJECT_NAME=$(basename "${CI_PROJECT_PATH}")
      MIRROR_URL="git@github.com:${GH_USER}/${PROJECT_NAME}.git"
      MIRROR_REPO="${GH_USER}/${PROJECT_NAME}"
      echo "Mirror target: ${MIRROR_REPO}"

      if [ -z "${GH_SSH_KEY}" ] || [ "${GH_SSH_KEY}" = "null" ]; then
        echo "ERROR: SSH key not found in Vault"
        exit 1
      fi

      # --- Set up SSH ---
      mkdir -p ~/.ssh
      echo "${GH_SSH_KEY}" > ~/.ssh/id_ed25519
      chmod 600 ~/.ssh/id_ed25519
      ssh-keyscan github.com >> ~/.ssh/known_hosts 2>/dev/null

      # --- Clone and sanitize with git-filter-repo ---
      WORK_DIR="/tmp/mirror-sanitize"
      rm -rf "${WORK_DIR}"
      git clone --branch main "${CI_REPOSITORY_URL}" "${WORK_DIR}"
      cd "${WORK_DIR}"

      # Strip this sync job from .gitlab-ci.yml before pushing
      python3 - .gitlab-ci.yml << 'STRIP_SYNC'
      import sys, re
      lines = open(sys.argv[1]).read().split('\n')
      lines = [l for l in lines if l.strip() != '- sync']
      idx = next((i for i,l in enumerate(lines) if l.startswith('sync-to-mirror:')), None)
      if idx is not None:
          d = idx
          for i in range(idx-1, max(idx-15,-1), -1):
              if lines[i].strip().startswith('#') or lines[i].strip() == '': d = i
              else: break
          while d > 0 and lines[d-1].strip() == '': d -= 1
          lines = lines[:d]
      pat = re.compile(r'sync-to-mirror|[Ss]yncs?\s+to\s+|[Ss]anitized\s+push|mirror|github.sanitize|[Rr]emoves?\s+PII|sensitive\s+configs?\s+before\s+pushing', re.I)
      out, i = [], 0
      while i < len(lines):
          if lines[i].strip().startswith('#') and pat.search(lines[i]):
              i += 1
              while i < len(lines) and lines[i].strip().startswith('#') and not lines[i].strip().startswith('# ---') and not lines[i].strip().startswith('# ==='):
                  r = lines[i].strip()[1:].strip()
                  if r and r[0].islower(): i += 1
                  else: break
              continue
          out.append(lines[i]); i += 1
      while out and out[-1].strip() == '': out.pop()
      out.append('')
      open(sys.argv[1],'w').write('\n'.join(out))
      STRIP_SYNC
      git add .gitlab-ci.yml
      git commit -m "ci: strip sync job for public mirror" --allow-empty 2>/dev/null || true

      # Define PII replacements (customize for your org)
      cat > /tmp/replacements.txt << 'REPLACEMENTS'
      internal.example.com==>example.com
      Your Org Name==>Example Org
      REPLACEMENTS

      # Pass 1: Replace PII in file content + remove sensitive paths
      git filter-repo \
        --replace-text /tmp/replacements.txt \
        --path-glob 'CLAUDE.md' --invert-paths \
        --path-glob '.claude' --invert-paths \
        --path-glob 'memory' --invert-paths \
        --path-glob 'docs/plans' --invert-paths \
        --path-glob 'shared/*.pem' --invert-paths \
        --force

      # Pass 2: Replace PII in commit messages
      git filter-repo \
        --message-callback '
      msg = message
      msg = msg.replace(b"internal.example.com", b"example.com")
      msg = msg.replace(b"Your Org Name", b"Example Org")
      return msg
      ' --force

      # Verify sanitization
      LEAKS=0
      for term in "internal.example.com" "Your Org Name"; do
        COUNT=$(grep -r "${term}" . --binary-files=without-match 2>/dev/null | grep -v ".git/" | wc -l || true)
        if [ "${COUNT}" -gt 0 ]; then
          echo "WARNING: Found ${COUNT} remaining '${term}' references"
          grep -r "${term}" . --binary-files=without-match 2>/dev/null | grep -v ".git/" | head -5 || true
          LEAKS=$((LEAKS + COUNT))
        fi
      done

      if [ "${LEAKS}" -gt 0 ]; then
        echo "ERROR: Sanitization incomplete — ${LEAKS} leaks found"
        exit 1
      fi
      echo "Sanitization verified — zero PII leaks"

      # --- Push to mirror ---
      git remote add mirror "${MIRROR_URL}"
      git push mirror main --force --tags
      echo "Sanitized push to mirror complete"

      # --- Verify mirror CI (optional, requires api-token) ---
      if [ -z "${GITHUB_API_TOKEN:-}" ] || [ "${GITHUB_API_TOKEN}" = "null" ]; then
        echo "API token not set — skipping CI status check"
        exit 0
      fi

      unset CURL_CA_BUNDLE 2>/dev/null || true
      GH_API="https://api.github.com/repos/${MIRROR_REPO}"
      GH_AUTH="Authorization: token ${GITHUB_API_TOKEN}"

      echo "Waiting for mirror CI to start..."
      sleep 15

      MAX_WAIT=300
      ELAPSED=0
      RUN_ID=""
      while [ "${ELAPSED}" -lt "${MAX_WAIT}" ]; do
        RUN_ID=$(curl -sf -H "${GH_AUTH}" \
          "${GH_API}/actions/runs?branch=main&per_page=1" | \
          jq -r '.workflow_runs[0].id // empty')

        if [ -n "${RUN_ID}" ]; then
          RUN_DATA=$(curl -sf -H "${GH_AUTH}" \
            "${GH_API}/actions/runs/${RUN_ID}")
          STATUS=$(echo "${RUN_DATA}" | jq -r '.status')
          CONCLUSION=$(echo "${RUN_DATA}" | jq -r '.conclusion // "null"')

          if [ "${STATUS}" = "completed" ]; then
            break
          fi
          echo "Mirror CI: ${STATUS} (${ELAPSED}/${MAX_WAIT}s)..."
        fi

        sleep 15
        ELAPSED=$((ELAPSED + 15))
      done

      if [ -z "${RUN_ID}" ]; then
        echo "WARNING: Could not find mirror CI run — no workflow configured?"
        exit 0
      fi

      if [ "${CONCLUSION}" = "success" ]; then
        echo "Mirror CI passed (run ${RUN_ID})"
      elif [ "${CONCLUSION}" = "null" ] || [ "${STATUS}" != "completed" ]; then
        echo "WARNING: Mirror CI did not complete within ${MAX_WAIT}s (status: ${STATUS})"
        exit 1
      else
        echo "ERROR: Mirror CI failed (run ${RUN_ID}, conclusion: ${CONCLUSION})"
        echo "See: https://github.com/${MIRROR_REPO}/actions/runs/${RUN_ID}"
        exit 1
      fi
  allow_failure: true
